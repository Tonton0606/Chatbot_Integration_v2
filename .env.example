# ═══════════════════════════════════════════════════════════════
# HERMESV2 / Exponify — Environment Variables
# Copy this file to server/.env and fill in your values.
# Variables marked [REQUIRED] will crash the server if missing.
# Variables marked [OPTIONAL] disable specific features when absent.
# ═══════════════════════════════════════════════════════════════

# ── Supabase [REQUIRED] ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Server [REQUIRED] ────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── URLs [REQUIRED for production] ──────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# ── AI Providers [OPTIONAL — at least one recommended] ──────────
# Primary: Groq (fast, free tier available)
GROQ_API_KEY=your_groq_api_key_here
# Fallback providers
NVIDIA_API_KEY=your_nvidia_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENCLAUDE_API_KEY=your_anthropic_api_key_here
XAI_API_KEY=your_xai_api_key_here
HOME_GROQ_API_KEY=your_home_groq_api_key_here

# Cerebras fallback for Facebook chatbot rate limits
CEREBRAS_API_KEY_FB=your_cerebras_api_key_fb_here
CEREBRAS_MODEL=gpt-oss-120b

# Intelligence module credential encryption (optional; falls back to service-role key)
INTELLIGENCE_CREDENTIALS_KEY=replace_with_32_plus_character_random_value

# ── Email [OPTIONAL — disables all email sending if absent] ─────
# Provider: smtp | sendgrid | mailgun
EMAIL_PROVIDER=smtp
EMAIL_FROM=Exponify <noreply@exponify.ph>

# SMTP (Gmail, Postmark, Mailtrap, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# SendGrid (alternative)
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.your_key_here

# Mailgun (alternative)
# EMAIL_PROVIDER=mailgun
# MAILGUN_HOST=smtp.mailgun.org
# MAILGUN_PORT=587
# MAILGUN_USERNAME=postmaster@mg.yourdomain.com
# MAILGUN_API_KEY=your_mailgun_key_here

# ── Facebook Integration [OPTIONAL] ─────────────────────────────
FB_PAGE_ID=your-facebook-page-id
FB_PAGE_ACCESS_TOKEN=your-facebook-page-access-token
FB_PAGE_NAME=Your Facebook Page Name
FB_BUSINESS_TYPE=Your Business Type
FB_PRODUCT_SERVICES=Your products and services description
FB_PRODUCT_SERVICE_PRICE_RANGES=Your pricing information
FB_WEBSITE_LINK=https://your-website.com
FB_SHOPPE_LINK=https://shopee.ph/your-shop
FB_LAZADA_LINK=https://lazada.com.ph/your-shop
FB_KNOWLEDGE=Your business knowledge base content
FB_AI_INSTRUCTION=Custom AI instructions for the chatbot
FB_VERIFY_TOKEN=your-webhook-verify-token
FB_APP_SECRET=your-facebook-app-secret
FACEBOOK_WEBHOOKS=https://your-domain.com/api/webhooks/facebook
INTERNAL_CHATBOT_URL=http://127.0.0.1:5000/api/openclaude/chat
FB_CHATBOT_MAX_TOKENS=220
FB_LEAD_QUALIFICATION_MODEL=llama-3.1-8b-instant

# ── Google Calendar / Zoom [OPTIONAL] ───────────────────────────
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=primary
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# ── Redis [OPTIONAL — AI caching falls back to in-memory] ───────
REDIS_URL=redis://localhost:6379

# ── Render Deployment [OPTIONAL] ────────────────────────────────
RENDER_CUSTOM_DOMAIN_TARGET=your-custom-domain.com

# ── Google Maps Lead Generator [OPTIONAL] ──────────────────────
# Get your API key at https://serper.dev/ (free credits available)
SERPER_API_KEY=your_serper_api_key_here
# AI enrichment uses OpenRouter (supports GPT-4, Claude, etc.)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Or use OpenAI directly:
# OPENAI_API_KEY=your_openai_api_key_here
# Model override — use an OpenRouter-compatible model ID when using OpenRouter
# Best cheap options: mistralai/mistral-7b-instruct, google/gemma-3-27b-it:free
LLM_MODEL=mistralai/mistral-7b-instruct
# GMAPS Microservice URL — points to the isolated gmaps HTTP container.
# In Docker Compose: http://gmaps:8000 (auto-resolved via Docker DNS)
# Standalone dev: http://localhost:8000
# If unreachable, the Node.js bridge falls back to spawning Python directly.
GMAPS_SERVICE_URL=http://gmaps:8000

# ── Stripe Billing [OPTIONAL — disables subscription module if absent] ──────
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_STARTER_PRICE_ID=price_starter_id_here
STRIPE_PROFESSIONAL_PRICE_ID=price_professional_id_here
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_id_here

# ── Email Compliance [RECOMMENDED] ──────────────────────────────────────────
# Secret for HMAC-signed unsubscribe tokens (CAN-SPAM / PH Data Privacy Act)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UNSUBSCRIBE_SECRET=your_random_32_byte_hex_here

# ── Feature Flags [OPTIONAL] ────────────────────────────────────
ENABLE_AI_CACHING=true
ENABLE_CONVERSATION_SUMMARIZATION=true
ENABLE_RATE_LIMITING=true
LOG_LEVEL=info
