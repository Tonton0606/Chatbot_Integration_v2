# Copy this to .env.local and fill in your actual values
# DO NOT commit .env.local to git

# Supabase Client (Public)
VITE_SUPABASE_URL=https://PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# API Base URL (supports both naming conventions)
VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_URL=http://localhost:5000/api

# Meta (Facebook) Pixel ID — from Meta Events Manager → Datasets
VITE_META_PIXEL_ID=your_pixel_id_here

# Facebook App ID — for Facebook JS SDK (FB.login auto-detect)
# Must match server FACEBOOK_APP_ID. Get it from developers.facebook.com
VITE_FACEBOOK_APP_ID=your_facebook_app_id_here

# Backend URL (used by some services as alternative to VITE_API_BASE_URL)
VITE_BACKEND_URL=https://your-backend.onrender.com

# Public site URL (used in og:url, canonical, and share links)
VITE_PUBLIC_SITE_URL=https://exponify.ph

# Render custom domain target (optional — for DNS CNAME verification)
VITE_RENDER_CUSTOM_DOMAIN_TARGET=

# Google reCAPTCHA v2 site key (used on public booking/contact forms)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# ─────────────────────────────────────────────
# Server-side env vars (set in .env, NOT here)
# ─────────────────────────────────────────────
# These are documentation only — set in the server .env:

# Email Service (choose one: sendgrid | mailgun | smtp)
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.xxx
# EMAIL_FROM=Exponify <noreply@exponify.ph>
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAILGUN_USERNAME=
# MAILGUN_API_KEY=

# Redis (for AI cache — optional, falls back to in-memory)
# REDIS_URL=redis://localhost:6379

# AI Token Budget (per workspace per day)
# AI_DAILY_TOKEN_LIMIT=100000

# Frontend URL (used in email templates)
# FRONTEND_URL=https://exponify.ph