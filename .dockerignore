# ─────────────────────────────────────────────────────────────────────────────
# HERMES v2.2.1 — Docker Ignore (Build Context Minimization)
# Exclude everything not needed at runtime to keep images small and builds fast.
# ─────────────────────────────────────────────────────────────────────────────

# Version control
.git/
.gitignore
.gitattributes
.gitmodules

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn/
.pnpm-store/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
dist/
*.egg

# Environment & secrets
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# IDE & editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Build artifacts
client/dist/
client/build/
server/build/
server/dist/
*.tsbuildinfo

# Logs
logs/
*.log
/var/log/

# Documentation & tests
docs/
tests/
test/
__tests__/
*.test.js
*.spec.js
*.test.ts
*.spec.ts

# Docker (build context doesn't need Dockerfiles)
docker/Dockerfile*
docker-compose.yml
docker-compose.override.yml
docker-compose.override.yml.example

# Scripts (not needed in final images)
scripts/
Makefile

# Database migrations (applied externally, not needed at runtime)
database/

# Backups & temp
backups/
tmp/
*.tmp
*.temp

# CI/CD
.github/
*.md
README.md
LICENSE

# Reports & artifacts
*.xml
*.html
coverage/
.nyc_output/