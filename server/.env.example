# Copy this to .env.local and fill in your actual values
# DO NOT commit .env.local to git

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Supabase Database
DATABASE_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
# Required for change-password credential verification (signInWithPassword)
# Find at: Supabase Dashboard > Settings > API > Project API Keys > anon/public
SUPABASE_ANON_KEY=your-supabase-anon-public-key-here
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_USER_EMAIL=your_zoom_email@gmail.com

# Google Calendar API
GOOGLE_CLIENT_EMAIL=calendar-bot@PROJECT.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=your_calendar_email@gmail.com
GOOGLE_MEET_LINK=https://meet.google.com/xxx-xxxx-xxx

# Email (Gmail SMTP)
EMAIL_PROVIDER=smtp
EMAIL_FROM=Exponify <noreply@exponify.ph>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Twilio SMS (optional — OTP SMS fallback when email fails)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=your_twilio_phone_number

# Groq AI API (get from https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=your_secondary_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=your_google_ai_api_key_here
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=your_openrouter_api_key_here
FB_OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
NVIDIA_API_KEY=your_nvidia_nim_api_key_here
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_MS=15000
FB_OLLAMA_PRIMARY_MODEL=llama-3.3-70b-versatile
FB_OLLAMA_FALLBACK_MODEL=gemma4:31b

# Intelligence module credential encryption
# Use a long random value. If omitted, SUPABASE_SERVICE_ROLE_KEY is used as the fallback key.
INTELLIGENCE_CREDENTIALS_KEY=replace_with_32_plus_character_random_value

# Cerebras AI API (fallback for FB chatbot rate limits)
CEREBRAS_API_KEY_FB=your_cerebras_api_key_fb_here
CEREBRAS_MODEL=gpt-oss-120b

# Facebook Chatbot Configuration
FB_PAGE_ID=your-facebook-page-id
FB_PAGE_ACCESS_TOKEN=your-facebook-page-access-token
FB_PAGE_NAME=Your Facebook Page Name
FB_BUSINESS_TYPE=Your Business Type
FB_PRODUCT_SERVICES=Your products and services description
FB_PRODUCT_SERVICE_PRICE_RANGES=Your pricing information
FB_WEBSITE_LINK=https://your-website.com
FB_SHOPPE_LINK=https://shopee.ph/your-shop
FB_LAZADA_LINK=https://lazada.com.ph/your-shop
FB_KNOWLEDGE=Your business knowledge base content
FB_AI_INSTRUCTION=Custom AI instructions for the chatbot
FB_VERIFY_TOKEN=your-webhook-verify-token
FB_APP_SECRET=your-facebook-app-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_WEBHOOKS=https://your-domain.com/api/webhooks/facebook
INTERNAL_CHATBOT_URL=http://127.0.0.1:5000/api/openclaude/chat
FB_CHATBOT_MAX_TOKENS=220
FB_LEAD_QUALIFICATION_MODEL=llama-3.1-8b-instant

# Omni-Channel (Instagram, TikTok, Shopee, Lazada)
# Instagram uses the same Meta Graph API as Facebook — same FB_APP_SECRET
INSTAGRAM_APP_SECRET=your-instagram-app-secret
# TikTok Business Messaging
TIKTOK_APP_ID=your-tiktok-app-id
TIKTOK_APP_SECRET=your-tiktok-app-secret
TIKTOK_VERIFY_TOKEN=your-tiktok-verify-token
# Shopee Open Platform (PH)
SHOPEE_PARTNER_ID=your-shopee-partner-id
SHOPEE_PARTNER_KEY=your-shopee-partner-key
# Lazada Open Platform (PH)
LAZADA_APP_KEY=your-lazada-app-key
LAZADA_APP_SECRET=your-lazada-app-secret

# Supabase keys can be found at: https://your-project.supabase.co/settings/api

# Secondary Groq Key for Fallback
# GROQ_API_KEY_2 is defined above with the AI provider settings.
