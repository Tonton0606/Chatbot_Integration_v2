{
  "name": "hermes-server",
  "version": "1.0.0",
  "main": "server/server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/__tests__/**/*.test.js"
    ],
    "setupFiles": [
      "./tests/setup.js"
    ],
    "testTimeout": 15000
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.59.0",
    "@supabase/supabase-js": "^2.105.0",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.6.1",
    "edge-tts-universal": "^1.4.0",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.0",
    "googleapis": "^171.4.0",
    "groq-sdk": "^1.2.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.1",
    "ip": "^2.0.1",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "pino": "^10.3.1",
    "pino-loki": "^2.6.0",
    "pino-pretty": "^13.1.3",
    "resend": "^6.12.4",
    "stripe": "^22.3.0",
    "tinyld": "^1.3.4",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "pg": "^8.21.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": "20.x"
  },
  "overrides": {
    "js-yaml": "4.2.0"
  }
}
