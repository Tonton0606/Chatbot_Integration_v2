{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" },
    { "type": "panel", "id": "logs", "name": "Logs", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Hermes Enterprise Portal — Operational Observability. Log volume, error rates, container streams, and x-request-id trace lookup.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "title": "System Health",
      "type": "row"
    },

    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Total log lines per container per minute. Spike = traffic surge or log flood.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "hermes-server" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "hermes-client" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "hermes-redis" },  "properties": [{ "id": "color", "value": { "fixedColor": "#F2CC0C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "hermes-gmaps" },  "properties": [{ "id": "color", "value": { "fixedColor": "#FF780A", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 7, "w": 16, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"] } },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (container) (rate({container=~\"hermes-.+\"}[1m]))",
          "legendFormat": "{{container}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log Volume — All Containers (lines/min)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Error log lines in the selected time range. Zero is the target.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({container=~\"hermes-.+\", level=\"error\"}[$__range]))",
          "legendFormat": "Errors",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Total Errors",
      "type": "stat"
    },

    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Warning log lines in the selected time range.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 25 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({container=~\"hermes-.+\", level=\"warn\"}[$__range]))",
          "legendFormat": "Warnings",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Total Warnings",
      "type": "stat"
    },

    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Error rate trend — errors per minute across all containers.",
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#F2495C", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 4 },
      "id": 4,
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "hidden" } },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({container=~\"hermes-.+\", level=\"error\"}[2m]))",
          "legendFormat": "errors/min",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Error Rate (errors/min)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "id": 11,
      "title": "Server — hermes-server",
      "type": "row"
    },

    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Live log stream from hermes-server. Filter by level or paste a reqId to trace a request end-to-end.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 9 },
      "id": 5,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container=\"hermes-server\"} | json | __error__=\"\"",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Server Logs",
      "type": "logs"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 12,
      "title": "Errors & Warnings — All Containers",
      "type": "row"
    },

    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "All error-level log lines across every Hermes container. First place to look after an alert.",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 20 },
      "id": 6,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container=~\"hermes-.+\", level=\"error\"}",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Error Stream — All Containers",
      "type": "logs"
    },

    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "All warn-level log lines across every Hermes container.",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 20 },
      "id": 7,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container=~\"hermes-.+\", level=\"warn\"}",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Warning Stream — All Containers",
      "type": "logs"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 13,
      "title": "x-request-id Trace Lookup",
      "type": "row"
    },

    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Paste an x-request-id value into the reqId variable at the top of the dashboard to see every log line for that request across all containers.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 31 },
      "id": 8,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Ascending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container=~\"hermes-.+\"} |= \"$reqId\"",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Trace — All logs for reqId: $reqId",
      "type": "logs"
    }

  ],

  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["hermes", "observability", "ops"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "", "value": "" },
        "description": "Paste an x-request-id value to trace a full request across all containers",
        "hide": 0,
        "label": "reqId (x-request-id)",
        "name": "reqId",
        "options": [],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({container=~\"hermes-.+\"}, container)",
        "description": "Filter to a single container",
        "hide": 0,
        "includeAll": true,
        "label": "Container",
        "multi": false,
        "name": "container",
        "options": [],
        "query": "label_values({container=~\"hermes-.+\"}, container)",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Manila",
  "title": "Hermes — Operational Overview",
  "uid": "hermes-ops-v1",
  "version": 1
}
